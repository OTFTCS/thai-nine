{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thai-nine.local/schemas/deck-source.schema.json",
  "title": "PPTX Deck Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lessonId",
    "sourceScript",
    "canvas",
    "theme",
    "slides"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "lessonId": { "type": "string", "pattern": "^M\\d{2}-L\\d{3}$" },
    "sourceScript": {
      "type": "string",
      "pattern": "^(M\\d{2}-L\\d{3}-)?script-master\\.json$"
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "leftTeachingFraction",
        "rightCameraFraction",
        "safeZoneLabel"
      ],
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 },
        "leftTeachingFraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "rightCameraFraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "pipCameraWidth": { "type": "number", "minimum": 0 },
        "pipCameraHeight": { "type": "number", "minimum": 0 },
        "pipPosition": { "type": "string", "enum": ["top-right", "bottom-right"] },
        "safeZoneLabel": { "type": "string", "minLength": 1 }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "thaiFont",
        "latinFont",
        "backgroundColor",
        "rightZoneTint",
        "accentColors"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "thaiFont": { "type": "string", "minLength": 1 },
        "latinFont": { "type": "string", "minLength": 1 },
        "backgroundColor": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "rightZoneTint": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accentColors": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role",
          "title",
          "estimatedSeconds",
          "layout",
          "speakerNotes",
          "textBlocks",
          "thaiFocus",
          "visualStrategy",
          "assets"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "role": {
            "enum": ["opener", "objectives", "teaching", "roleplay", "recap", "closing"]
          },
          "title": { "type": "string", "minLength": 1 },
          "estimatedSeconds": { "type": "number", "minimum": 8 },
          "layout": { "type": "string", "minLength": 1 },
          "speakerNotes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "textBlocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "kind", "lines"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "kind": {
                  "enum": [
                    "eyebrow",
                    "bullet-list",
                    "triplet-list",
                    "dialogue",
                    "recap-list",
                    "closing-list",
                    "note"
                  ]
                },
                "heading": { "type": "string", "minLength": 1 },
                "lines": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          },
          "thaiFocus": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["thai", "translit", "english"],
              "properties": {
                "thai": { "type": "string", "minLength": 1 },
                "translit": { "type": "string", "minLength": 1 },
                "english": { "type": "string", "minLength": 1 }
              }
            }
          },
          "visualStrategy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "onScreenGoal",
              "teachingVisuals",
              "teacherCues",
              "imageUsage",
              "rationale"
            ],
            "properties": {
              "onScreenGoal": { "type": "string", "minLength": 1 },
              "teachingVisuals": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "teacherCues": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "imageUsage": {
                "enum": ["real-image", "icon", "text-only"]
              },
              "rationale": { "type": "string", "minLength": 1 }
            }
          },
          "assets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "assetId",
                "kind",
                "query",
                "sourcePolicy",
                "status",
                "sourceProvider"
              ],
              "properties": {
                "assetId": { "type": "string", "minLength": 1 },
                "kind": { "enum": ["image"] },
                "query": { "type": "string", "minLength": 1 },
                "sourcePolicy": { "const": "internet-first" },
                "status": {
                  "enum": ["resolved", "fallback-text-only", "not-needed"]
                },
                "sourceProvider": {
                  "enum": ["openverse", "wikimedia", "none"]
                },
                "sourceUrl": { "type": "string", "pattern": "^https://" },
                "license": { "type": "string", "minLength": 1 },
                "localPath": { "type": "string", "minLength": 1 },
                "usageNotes": { "type": "string", "minLength": 1 },
                "fallbackReason": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
