{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thai-nine.local/schemas/remotion.schema.json",
  "title": "Remotion Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "lessonId", "sourceScript", "scenes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "lessonId": { "type": "string", "pattern": "^M\\d{2}-L\\d{3}$" },
    "sourceScript": {
      "type": "string",
      "pattern": "^(M\\d{2}-L\\d{3}-)?script-master\\.json$"
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "leftTeachingFraction",
        "rightCameraFraction",
        "safeZoneLabel"
      ],
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 },
        "leftTeachingFraction": { "type": "number", "minimum": 0.1, "maximum": 1 },
        "rightCameraFraction": { "type": "number", "minimum": 0.1, "maximum": 1 },
        "safeZoneLabel": { "type": "string", "minLength": 1 }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "seconds", "voiceover", "overlays", "thaiFocus", "assets"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "seconds": { "type": "number", "minimum": 20 },
          "voiceover": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "overlays": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "teachingObjective": { "type": "string", "minLength": 1 },
          "layout": {
            "enum": [
              "focus-card",
              "contrast-board",
              "dialogue-ladder",
              "drill-stack",
              "image-anchored"
            ]
          },
          "visualStrategy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "onScreenGoal",
              "teachingVisuals",
              "teacherCues",
              "imageUsage",
              "rationale"
            ],
            "properties": {
              "onScreenGoal": { "type": "string", "minLength": 1 },
              "teachingVisuals": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "teacherCues": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "imageUsage": {
                "enum": ["real-image", "icon", "text-only"]
              },
              "rationale": { "type": "string", "minLength": 1 }
            }
          },
          "thaiFocus": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["thai", "translit", "english"],
              "properties": {
                "thai": { "type": "string", "minLength": 1 },
                "translit": { "type": "string", "minLength": 1 },
                "english": { "type": "string", "minLength": 1 }
              }
            }
          },
          "assets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetId", "kind", "query", "sourcePolicy", "sourceUrl", "license"],
              "properties": {
                "assetId": { "type": "string", "minLength": 1 },
                "kind": { "enum": ["image", "icon", "video"] },
                "query": { "type": "string", "minLength": 1 },
                "sourcePolicy": { "const": "internet-first" },
                "sourceUrl": { "type": "string", "pattern": "^https://" },
                "license": { "type": "string", "minLength": 1 },
                "usageNotes": { "type": "string", "minLength": 1 },
                "aiFallbackPrompt": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
