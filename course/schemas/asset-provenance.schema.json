{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thai-nine.local/schemas/asset-provenance.schema.json",
  "title": "Asset Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "lessonId", "generatedAt", "assets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "lessonId": { "type": "string", "pattern": "^M\\d{2}-L\\d{3}$" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "assets": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assetId", "kind", "usage"],
        "properties": {
          "assetId": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["image", "icon", "video"] },
          "status": {
            "enum": ["resolved", "fallback-text-only", "not-needed"]
          },
          "slideId": { "type": "string", "minLength": 1 },
          "sourceProvider": {
            "enum": ["openverse", "wikimedia", "none"]
          },
          "sourceUrl": { "type": "string", "pattern": "^https://" },
          "license": { "type": "string", "minLength": 1 },
          "usage": { "type": "string", "minLength": 1 },
          "query": { "type": "string", "minLength": 1 },
          "sourcePolicy": { "const": "internet-first" },
          "localPath": { "type": "string", "minLength": 1 },
          "fallbackReason": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "sourceHints": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "aiFallbackPrompt": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
