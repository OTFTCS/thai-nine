    "fadeIn": true
  },
  {
    "lineId": "l-0004",
    "blockId": "b-002",
    "mode": "explain",
    "lang": "en",
    "text": "When I first moved to Bangkok, there was this noodle stall near my apartment. Every morning, the same aunty would shout at me — สั่งอะไรดีคะ — and I had no idea what to say. I just pointed at the picture.",
    "displayStart": 38.92,
    "displayEnd": 63.0,
    "style": "English",
    "highlight": false,
    "fadeIn": false
  },
  {
    "lineId": "l-0005",
