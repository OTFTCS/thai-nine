# Google Gemini (for image generation pipeline)
GEMINI_API_KEY=

# Kit (formerly ConvertKit) — v4 API
# Get from: https://app.kit.com/account_settings/developer_settings
KIT_API_KEY=

# Tag IDs (from Kit dashboard > Subscribers > Tags — click a tag, grab ID from URL)
KIT_TAG_NEWSLETTER=
KIT_TAG_WAITLIST=
KIT_TAG_CHEAT_SHEET=

# Creator dashboard social APIs (TODO: fill in before flipping DRY_RUN off)
# Leave SOCIAL_DRY_RUN unset or "true" to keep publishing inert on localhost.
SOCIAL_DRY_RUN=true
IG_GRAPH_ACCESS_TOKEN=
IG_USER_ID=
TIKTOK_ACCESS_TOKEN=

# Supabase (diagnostic quiz persistence)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public-deploy gate. Set to "true" in Vercel; leave unset locally so admin works.
IS_PUBLIC_DEPLOY=
