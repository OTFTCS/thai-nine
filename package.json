{
  "name": "thai-nine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types --loader ./tests/unit/alias-loader.mjs tests/unit/*.test.ts",
    "course:validate": "node --experimental-strip-types course/tools/pipeline-cli.ts validate",
    "course:validate:schemas": "node --experimental-strip-types course/tools/pipeline-cli.ts validate-schemas",
    "course:validate:lesson": "node --experimental-strip-types course/tools/pipeline-cli.ts validate --lesson",
    "course:produce": "node --experimental-strip-types course/tools/produce-lesson.ts",
    "course:fixup-vocabids": "node --experimental-strip-types course/tools/pipeline-cli.ts fixup-vocabids",
    "course:lint": "npm run lint && npm run course:validate",
    "course:runlog": "node --experimental-strip-types course/tools/pipeline-cli.ts touch-runlog --message",
    "course:translit-audit": "node --experimental-strip-types course/tools/pipeline-cli.ts translit-audit",
    "course:translit-audit:fix": "node --experimental-strip-types course/tools/pipeline-cli.ts translit-audit --fix",
    "course:test:translit": "node --experimental-strip-types --test course/tools/tests/transliteration-policy.test.ts",
    "course:pdf": "node --experimental-strip-types course/tools/export-pdf.ts",
    "course:pdf:lesson": "node --experimental-strip-types course/tools/export-pdf.ts --lesson",
    "tiktok:script": "node --experimental-strip-types thai_with_nine_tiktok/tools/tiktok-cli.ts generate-script",
    "tiktok:validate-script": "node --experimental-strip-types thai_with_nine_tiktok/tools/tiktok-cli.ts validate-script",
    "tiktok:build-post": "node --experimental-strip-types thai_with_nine_tiktok/tools/tiktok-cli.ts build-post",
    "tiktok:produce": "npm run tiktok:build-post --",
    "tiktok:test": "node --experimental-strip-types --test thai_with_nine_tiktok/tools/tests/pipeline.test.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "next": "16.1.6",
    "puppeteer-core": "^24.41.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pdfkit": "^0.17.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
